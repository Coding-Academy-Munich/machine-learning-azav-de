{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff format \"$CLAUDE_FILE_PATH\"",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "uv run ruff check --fix \"$CLAUDE_FILE_PATH\"",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
